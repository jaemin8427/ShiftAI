<Window x:Class="ShiftAI.GetoMock.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Geto Mock" Height="760" Width="1220" MinHeight="720" MinWidth="1080"
        Background="#202020" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#303030"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,14"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="28,0,22,12"/>
        </Style>
        <Style x:Key="PaymentButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#5A5A5A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="5"/>
        </Style>
        <Style x:Key="CardButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Width" Value="210"/>
            <Setter Property="Height" Value="236"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid x:Name="MainPanel" Visibility="Visible" Margin="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="112"/>
                <RowDefinition Height="136"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="36"/>
            </Grid.RowDefinitions>

            <Border Background="#4A4D50" CornerRadius="18" Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="76"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="☰" Foreground="White" FontSize="38" VerticalAlignment="Top" HorizontalAlignment="Center"/>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="좌석 38" Foreground="#D7D7D7" FontSize="14"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="남은시간" Foreground="White" FontSize="15" VerticalAlignment="Bottom"/>
                            <TextBlock Text="3999783:07" Foreground="White" FontSize="28" Margin="6,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,14,0,0">
                            <TextBlock Text="자동충전" Foreground="White" FontSize="16" Margin="0,0,14,0"/>
                            <Border Width="54" Height="28" Background="#6F7479" CornerRadius="14">
                                <Ellipse Width="22" Height="22" Fill="#A9ADB1" HorizontalAlignment="Left" Margin="5,3"/>
                            </Border>
                            <Button Content="설정" Margin="12,0,0,0" Padding="12,6" Background="#5B5E62" Foreground="White" BorderThickness="0"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="2" Content="⏻&#x0a;종료" Foreground="White" Background="#3D4044" BorderThickness="0" FontSize="16"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="20,18">
                <UniformGrid Columns="2" Height="58">
                    <Button Content="◷  시간충전" FontSize="22" FontWeight="Bold" Background="#FAFAFA" BorderThickness="0" Margin="0,0,8,0"/>
                    <Button x:Name="FoodOrderButton"
                            Content="🍴  음식주문"
                            FontSize="22"
                            FontWeight="Bold"
                            Background="#FAFAFA"
                            BorderThickness="0"
                            Margin="8,0,0,0"
                            Click="FoodOrderButton_Click"/>
                </UniformGrid>
                <Grid Height="50" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="#262626" CornerRadius="8" Margin="0,0,8,0" Padding="20,0">
                        <TextBlock Text="reila0102 ▾" Foreground="White" FontSize="16" VerticalAlignment="Center"/>
                    </Border>
                    <Border Grid.Column="1" Background="#262626" Margin="0,0,8,0" Padding="20,0">
                        <TextBlock Text="게토포인트&#x0a;0 P" Foreground="White" FontSize="14" TextAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Grid.Column="2" Background="#262626" CornerRadius="8" Padding="20,0">
                        <TextBlock Text="쿠폰&#x0a;0장" Foreground="White" FontSize="14" TextAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </StackPanel>

            <Grid Grid.Row="2" Background="#53565A">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="78"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Background="#3D4145" Margin="0,110,0,0">
                    <TextBlock Text="FC온라인" Foreground="White" FontWeight="Bold" Margin="10"/>
                    <TextBlock Text="던전앤파이터" Foreground="White" FontWeight="Bold" Margin="10"/>
                    <TextBlock Text="메이플스토리" Foreground="White" FontWeight="Bold" Margin="10"/>
                    <TextBlock Text="한게임포커" Foreground="White" FontWeight="Bold" Margin="10"/>
                    <TextBlock Text="서든어택" Foreground="White" FontWeight="Bold" Margin="10"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="18">
                    <TextBlock Text="추천 메뉴" Foreground="#E8E8E8" FontSize="16" Margin="0,0,0,10"/>
                    <UniformGrid Columns="5" Height="64">
                        <Border Background="#F3E4B4" Margin="5" CornerRadius="6"><TextBlock Text="제로콜라" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                        <Border Background="#F3E4B4" Margin="5" CornerRadius="6"><TextBlock Text="아이스티" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                        <Border Background="#F3E4B4" Margin="5" CornerRadius="6"><TextBlock Text="생수" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                        <Border Background="#F3E4B4" Margin="5" CornerRadius="6"><TextBlock Text="라공탄" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                        <Border Background="#F3E4B4" Margin="5" CornerRadius="6"><TextBlock Text="컵얼음" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                    </UniformGrid>
                    <Border Background="#18142A" CornerRadius="10" Margin="0,26,0,0" Height="330">
                        <TextBlock Text="FC ONLINE&#x0a;&#x0a;소년이어 저석이 되기까지&#x0a;&#x0a;보상의 여정에 동참하기"
                                   Foreground="White"
                                   FontSize="34"
                                   TextAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Grid>

            <DockPanel Grid.Row="3" Background="#474A4E">
                <TextBlock Text="이용약관" Foreground="#D6D6D6" Margin="60,0" VerticalAlignment="Center"/>
                <TextBlock Text="개인정보처리방침" Foreground="#D6D6D6" Margin="180,0" VerticalAlignment="Center"/>
            </DockPanel>
        </Grid>

        <Grid x:Name="OrderPanel" Visibility="Collapsed" Background="#222">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="470"/>
            </Grid.ColumnDefinitions>

            <StackPanel Background="#303030">
                <Border Background="#202020" CornerRadius="8" Margin="28,20" Height="44">
                    <TextBlock Text="⌕  메뉴 검색" Foreground="#9B9B9B" VerticalAlignment="Center" Margin="18,0" FontSize="16"/>
                </Border>
                <Button Content="추천상품" Style="{StaticResource MenuButton}" Background="#0877DB"/>
                <Button Content="이달의 음식" Style="{StaticResource MenuButton}"/>
                <Button Content="아이스크림스무디" Style="{StaticResource MenuButton}"/>
                <Button Content="팝스에너지드링크" Style="{StaticResource MenuButton}"/>
                <Button Content="세트 메뉴" Style="{StaticResource MenuButton}"/>
                <Button Content="라면" Style="{StaticResource MenuButton}"/>
                <Button Content="밥" Style="{StaticResource MenuButton}"/>
                <Button Content="간식" Style="{StaticResource MenuButton}"/>
                <Button Content="디스펜서 음료" Style="{StaticResource MenuButton}"/>
                <Button Content="Cafe" Style="{StaticResource MenuButton}"/>
                <Button Content="H O T" Style="{StaticResource MenuButton}"/>
            </StackPanel>

            <Grid Grid.Column="1" Background="#202020">
                <Grid.RowDefinitions>
                    <RowDefinition Height="82"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Background="#0E0E0E" CornerRadius="8" Margin="24,20">
                    <TextBlock Text="!!! 이달의 음식 주문 시 서비스 시간 60분 제공 !!!" Foreground="#FF8A00" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Margin="20,0"/>
                </Border>
                <ScrollViewer Grid.Row="1">
                    <WrapPanel Margin="14">
                        <Button Style="{StaticResource CardButton}" Click="FoodCard_Click" Tag="라공탄|6900">
                            <StackPanel>
                                <Border Background="#C9B98B" Height="145"><TextBlock Text="라공탄" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                <TextBlock Text="Best" Foreground="White" Background="#16A36A" Width="78"/>
                                <TextBlock Text="라공탄" Margin="10,8,0,0" FontSize="15"/>
                                <TextBlock Text="6,900원" Margin="10,20,0,0" FontSize="20" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource CardButton}" Click="FoodCard_Click" Tag="라우동|8000">
                            <StackPanel>
                                <Border Background="#B99C65" Height="145"><TextBlock Text="라우동" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                <TextBlock Text="New" Foreground="White" Background="#248BD8" Width="70"/>
                                <TextBlock Text="라우동" Margin="10,8,0,0" FontSize="15"/>
                                <TextBlock Text="8,000원" Margin="10,20,0,0" FontSize="20" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource CardButton}" Click="FoodCard_Click" Tag="도도한 나초|2500">
                            <StackPanel>
                                <Border Background="#D9C486" Height="145"><TextBlock Text="Nacho" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                <TextBlock Text="New" Foreground="White" Background="#248BD8" Width="70"/>
                                <TextBlock Text="도도한 나초" Margin="10,8,0,0" FontSize="15"/>
                                <TextBlock Text="2,500원" Margin="10,20,0,0" FontSize="20" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="ColaItemButton"
                                Style="{StaticResource CardButton}"
                                Click="FoodCard_Click"
                                Tag="콜라|2500">
                            <StackPanel>
                                <Border Background="#D7C28A" Height="145">
                                    <TextBlock Text="COLA" Foreground="#8B1730" FontSize="34" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="New" Foreground="White" Background="#248BD8" Width="70"/>
                                <TextBlock Text="콜라" Margin="10,8,0,0" FontSize="15"/>
                                <TextBlock Text="2,500원" Margin="10,20,0,0" FontSize="20" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource CardButton}" Click="FoodCard_Click" Tag="아이스티|3000">
                            <StackPanel>
                                <Border Background="#DCC98C" Height="145"><TextBlock Text="ICE TEA" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                <TextBlock Text="New" Foreground="White" Background="#248BD8" Width="70"/>
                                <TextBlock Text="아이스티" Margin="10,8,0,0" FontSize="15"/>
                                <TextBlock Text="3,000원" Margin="10,20,0,0" FontSize="20" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </ScrollViewer>
            </Grid>

            <Grid Grid.Column="2" Background="#343434">
                <Grid.RowDefinitions>
                    <RowDefinition Height="84"/>
                    <RowDefinition Height="390"/>
                    <RowDefinition Height="62"/>
                    <RowDefinition Height="120"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <DockPanel Margin="22,0">
                    <Button DockPanel.Dock="Right" Content="×" Width="56" Height="56" FontSize="38" Foreground="White" Background="#6B6B6B" BorderThickness="0" Click="CloseOrderButton_Click"/>
                    <TextBlock Text="좌석번호 38" Foreground="White" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button Content="주문내역 보기" Margin="18,0,0,0" Padding="14,8" Background="#5B5B5B" Foreground="White" BorderThickness="0"/>
                </DockPanel>
                <Border Grid.Row="1" Background="#202020" CornerRadius="7" Margin="20,0">
                    <Grid>
                        <ListBox x:Name="CartList" Background="#202020" Foreground="White" BorderThickness="0" FontSize="18" Margin="16,16,16,66" MouseDoubleClick="CartList_MouseDoubleClick"/>
                        <TextBlock x:Name="EmptyCartText" Text="주문할 상품을 선택하세요" Foreground="#727272" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,16,16">
                            <Button x:Name="RemoveSelectedButton"
                                    Content="선택 삭제"
                                    Foreground="White"
                                    Background="#5B5B5B"
                                    BorderThickness="0"
                                    Padding="18,10"
                                    Margin="0,0,8,0"
                                    Click="RemoveSelectedButton_Click"/>
                            <Button x:Name="ClearCartButton"
                                    Content="전체 삭제"
                                    Foreground="White"
                                    Background="#8A3A3A"
                                    BorderThickness="0"
                                    Padding="18,10"
                                    Click="ClearCartButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <DockPanel Grid.Row="2" Margin="20,0">
                    <TextBlock Text="총 주문금액" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TotalText" Text="0 원" Foreground="White" FontSize="26" FontWeight="Bold" DockPanel.Dock="Right" VerticalAlignment="Center"/>
                </DockPanel>
                <StackPanel Grid.Row="3">
                    <Border Background="#FFE900" Height="62">
                        <TextBlock Text="자동결제 등록하고 카카오페이로 간편하게 결제하세요" Foreground="Black" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" Margin="22,0"/>
                    </Border>
                    <UniformGrid Columns="3" Margin="18,14,18,0">
                        <Button Content="현금" Style="{StaticResource PaymentButton}"/>
                        <Button Content="신용카드" Style="{StaticResource PaymentButton}"/>
                        <Button Content="게토앱결제" Style="{StaticResource PaymentButton}"/>
                    </UniformGrid>
                </StackPanel>
                <StackPanel Grid.Row="4" Margin="20,16">
                    <Border Background="#171717" Height="80" CornerRadius="7"/>
                    <TextBox Text="요청사항은 50자까지 입력할 수 있습니다." Foreground="#7D7D7D" Background="#202020" BorderBrush="#444" Height="38" Margin="0,10"/>
                    <Button x:Name="OrderButton"
                            Content="주문하기"
                            Foreground="White"
                            Background="#238FF0"
                            FontSize="24"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Height="66"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
