<Window x:Class="ShiftAI.App.VoiceFloatingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shift AI Voice"
        Width="150" Height="48"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewKeyUp="Window_PreviewKeyUp"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseMove="Window_MouseMove"
        MouseLeftButtonUp="Window_MouseLeftButtonUp">
    <Border x:Name="MainBorder"
            Background="#F2070A16"
            BorderBrush="#FF3EC8"
            BorderThickness="1"
            CornerRadius="8"
            Padding="7,5">
        <Border.Effect>
            <DropShadowEffect Color="#FF3EC8" BlurRadius="16" ShadowDepth="0" Opacity=".45"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="18"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Ellipse x:Name="LiveDot"
                     Width="7"
                     Height="7"
                     Fill="#FF3EC8"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     Margin="0,3,0,0">
                <Ellipse.Effect>
                    <DropShadowEffect Color="#FF3EC8" BlurRadius="10" ShadowDepth="0" Opacity=".9"/>
                </Ellipse.Effect>
            </Ellipse>

            <TextBlock x:Name="TitleText"
                       Text="SHIFT AI"
                       Foreground="#CFE9FF"
                       FontFamily="Consolas"
                       FontSize="10"
                       Margin="13,-1,24,0"
                       VerticalAlignment="Top"/>

            <TextBlock x:Name="SeatText"
                       Text="PC-38"
                       Visibility="Collapsed"
                       Foreground="#5F7596"
                       FontFamily="Consolas"
                       FontSize="11"
                       HorizontalAlignment="Right"
                       Margin="0,0,24,0"
                       VerticalAlignment="Top"/>

            <Button x:Name="CloseButton"
                    Content="×"
                    Width="18"
                    Height="16"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="#5F7596"
                    FontFamily="Consolas"
                    FontSize="11"
                    Click="CloseButton_Click"/>

            <Border x:Name="WaveBox"
                    Grid.Row="1"
                    Height="22"
                    VerticalAlignment="Center"
                    BorderBrush="#5522F0FF"
                    BorderThickness="1"
                    CornerRadius="5"
                    Background="#C002040A"
                    ClipToBounds="True">
                <Grid>
                    <Polyline x:Name="WaveLine"
                              Stroke="#FF3EC8"
                              StrokeThickness="1.4"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Points="0,11 12,10 24,12 36,8 48,13 60,10 72,12 84,9 96,11"/>
                    <Rectangle Opacity=".32">
                        <Rectangle.Fill>
                            <DrawingBrush TileMode="Tile" Viewport="0,0,4,4" ViewportUnits="Absolute">
                                <DrawingBrush.Drawing>
                                    <DrawingGroup>
                                        <GeometryDrawing Brush="Transparent">
                                            <GeometryDrawing.Geometry>
                                                <RectangleGeometry Rect="0,0,4,4"/>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                        <GeometryDrawing Brush="#33000000">
                                            <GeometryDrawing.Geometry>
                                                <RectangleGeometry Rect="0,2,4,1"/>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                    </DrawingGroup>
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                </Grid>
            </Border>

            <StackPanel x:Name="TranscriptPanel"
                        Grid.Row="2"
                        Visibility="Collapsed"
                        Margin="0,8,0,0">
                <TextBlock Text="인식된 음성"
                           Foreground="#5F7596"
                           FontFamily="Consolas"
                           FontSize="11"/>
                <TextBlock x:Name="TranscriptText"
                           Text="&quot;대기 중&quot;"
                           Foreground="#CFE9FF"
                           FontFamily="Consolas"
                           FontSize="13"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <Button x:Name="PttButton"
                    Grid.Row="3"
                    Visibility="Collapsed"
                    Content="⌨ 누르고 있는 동안 듣기 (SPACE)"
                    Height="44"
                    Margin="0,12,0,0"
                    Foreground="#FF3EC8"
                    Background="#22FF3EC8"
                    BorderBrush="#FF3EC8"
                    BorderThickness="1"
                    FontFamily="Consolas"
                    FontSize="13"
                    PreviewMouseLeftButtonDown="PttButton_PreviewMouseLeftButtonDown"
                    PreviewMouseLeftButtonUp="PttButton_PreviewMouseLeftButtonUp">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <TextBlock x:Name="FootText"
                       Grid.Row="4"
                       Visibility="Collapsed"
                       Text="채팅 화면으로 돌아가려면 SHIFT+A+I · 닫으려면 ESC"
                       Foreground="#775F7596"
                       FontFamily="Consolas"
                       FontSize="10"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,12,0,0"/>
        </Grid>
    </Border>
</Window>
