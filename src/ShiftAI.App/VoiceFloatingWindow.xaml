<Window x:Class="ShiftAI.App.VoiceFloatingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shift AI Voice"
        Width="350" Height="260"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewKeyUp="Window_PreviewKeyUp"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.Resources>
        <SolidColorBrush x:Key="CyanBrush" Color="#22F0FF"/>
        <SolidColorBrush x:Key="MagentaBrush" Color="#FF3EC8"/>
        <SolidColorBrush x:Key="InkBrush" Color="#CFE9FF"/>
        <SolidColorBrush x:Key="DimBrush" Color="#5F7596"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#EF070A16"/>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource MagentaBrush}"/>
            <Setter Property="Background" Value="#22FF3EC8"/>
            <Setter Property="BorderBrush" Value="{StaticResource MagentaBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="13,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#44FF3EC8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF3EC8"/>
                                <Setter Property="Foreground" Value="#170312"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource MagentaBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="16">
        <Border.Effect>
            <DropShadowEffect Color="#FF3EC8" BlurRadius="24" ShadowDepth="0" Opacity=".38"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="24"/>
                <RowDefinition Height="66"/>
                <RowDefinition Height="52"/>
                <RowDefinition Height="52"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0">
                <TextBlock Text="PC-38" DockPanel.Dock="Right" Foreground="{StaticResource DimBrush}" FontSize="11" FontFamily="Consolas"/>
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="LiveDot" Width="9" Height="9" Fill="{StaticResource MagentaBrush}" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#FF3EC8" BlurRadius="10" ShadowDepth="0" Opacity=".9"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock Text="SHIFT AI · 음성 모드" Foreground="{StaticResource InkBrush}" FontSize="12" FontFamily="Consolas"/>
                </StackPanel>
            </DockPanel>

            <Border Grid.Row="1" BorderBrush="#6622F0FF" BorderThickness="1" CornerRadius="7" Background="#AA02040A" Margin="0,10,0,0" ClipToBounds="True">
                <Grid>
                    <Polyline x:Name="WaveLine"
                              Points="0,34 24,31 48,33 72,37 96,35 120,31 144,30 168,35 192,38 216,34 240,30 264,34 288,38 318,34"
                              Stroke="{StaticResource MagentaBrush}"
                              StrokeThickness="1.7"
                              Stretch="Fill"
                              Margin="0,12">
                        <Polyline.RenderTransform>
                            <ScaleTransform x:Name="WaveScale" ScaleY="1" CenterY="33"/>
                        </Polyline.RenderTransform>
                    </Polyline>
                    <Rectangle Opacity=".36">
                        <Rectangle.Fill>
                            <DrawingBrush TileMode="Tile" Viewport="0,0,4,4" ViewportUnits="Absolute">
                                <DrawingBrush.Drawing>
                                    <DrawingGroup>
                                        <GeometryDrawing Brush="Transparent">
                                            <GeometryDrawing.Geometry>
                                                <RectangleGeometry Rect="0,0,4,4"/>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                        <GeometryDrawing Brush="#33000000">
                                            <GeometryDrawing.Geometry>
                                                <RectangleGeometry Rect="0,2,4,1"/>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                    </DrawingGroup>
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                </Grid>
            </Border>

            <StackPanel Grid.Row="2" Margin="0,8,0,0">
                <TextBlock Text="인식된 음성" Foreground="{StaticResource DimBrush}" FontSize="11" FontFamily="Consolas"/>
                <TextBlock x:Name="TranscriptText" Text="&quot;대기 중&quot;" Foreground="{StaticResource InkBrush}" FontSize="13" FontFamily="Consolas" TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>

            <Button x:Name="PttButton"
                    Grid.Row="3"
                    Content="⌨ 누르고 있는 동안 듣기 (SPACE)"
                    Margin="0,10,0,0"
                    PreviewMouseDown="PttButton_PreviewMouseDown"
                    PreviewMouseUp="PttButton_PreviewMouseUp"/>

            <DockPanel Grid.Row="4" LastChildFill="False" Margin="0,14,0,0">
                <TextBlock Text="채팅 화면으로 돌아가려면 SHIFT+A+I · 닫으려면 ESC"
                           Foreground="{StaticResource DimBrush}"
                           FontSize="10"
                           FontFamily="Consolas"
                           VerticalAlignment="Bottom"/>
            </DockPanel>
        </Grid>
    </Border>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard RepeatBehavior="Forever">
                    <DoubleAnimation Storyboard.TargetName="LiveDot" Storyboard.TargetProperty="Opacity" From=".45" To="1" Duration="0:0:.7" AutoReverse="True"/>
                    <DoubleAnimation Storyboard.TargetName="WaveScale" Storyboard.TargetProperty="ScaleY" From=".75" To="1.35" Duration="0:0:.6" AutoReverse="True"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>
